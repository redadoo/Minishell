{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*.c",
                "${workspaceFolder}/ft_libft/*.c",
                "${workspaceFolder}/src/env/*.c",
                "${workspaceFolder}/src/lexer/*.c",
                "${workspaceFolder}/src/parser/*.c",
                "${workspaceFolder}/src/signals/*.c",
                "${workspaceFolder}/src/builtins/*.c",
                "${workspaceFolder}/src/help_file/*.c",
                "${workspaceFolder}/src/exe/*.c",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lreadline"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}